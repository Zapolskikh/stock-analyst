# ============================================================
#  stock-analyst — environment variables
#  Copy this file to .env and fill in your values.
#  .env is git-ignored and must never be committed.
# ============================================================


# ------------------------------------------------------------
# DATA PROVIDERS
# ------------------------------------------------------------

# Financial Modeling Prep (optional)
# Free tier: 250 requests/day. Needed for:
#   - explicit ROIC & normalised FCF
#   - forward EPS estimates
#   - international ticker fundamentals
# Get key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Alpha Vantage (optional)
# Free tier: 25 requests/day. Useful for:
#   - intraday price data
#   - extended fundamental data
# Get key at: https://www.alphavantage.co/support/#api-key
AV_API_KEY=

# ------------------------------------------------------------
# CACHE
# ------------------------------------------------------------

# Directory where fetched data is cached (relative to project root)
# Default: data/cache
CACHE_DIR=data/cache

# How many hours before cached data is considered stale and re-fetched
# Default: 24
CACHE_TTL_HOURS=24

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR
# Default: INFO
LOG_LEVEL=INFO
