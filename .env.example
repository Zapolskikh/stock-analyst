# ============================================================
#  stock-analyst — environment variables
#  Copy this file to .env and fill in your values.
#  .env is git-ignored and must never be committed.
# ============================================================


# ------------------------------------------------------------
# DATA PROVIDERS
# ------------------------------------------------------------

# Financial Modeling Prep (optional)
FMP_API_KEY=

# Alpha Vantage (optional)
AV_API_KEY=

# ------------------------------------------------------------
# AI
# ------------------------------------------------------------

# Anthropic Claude API key (required for AI review step)
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# TELEGRAM
# ------------------------------------------------------------

# Bot token — получить у @BotFather
TELEGRAM_BOT_TOKEN=

# Канал/чат для сигналов (ID начинается с -100 для супергрупп)
TELEGRAM_OUTPUT_CHAT_ID=

# Отдельный чат для алёртов при ошибках (если не задан — шлёт в OUTPUT_CHAT_ID)
# Можно поставить личный chat_id оператора, чтобы не мешать сигнальному каналу
TELEGRAM_MONITOR_CHAT_ID=

# ------------------------------------------------------------
# SCHEDULER
# ------------------------------------------------------------

# Час запуска по ET (Eastern Time).  По умолчанию 10:30 AM ET
# (через 1 час после открытия NYSE в 9:30 AM ET — данные стабильны)
SCAN_RUN_HOUR=10
SCAN_RUN_MINUTE=30

# ------------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------------

# Режим работы: production или dev (по умолчанию dev)
# В production: AI-логи не пишутся на диск (только stdout)
# Устанавливается автоматически через docker-compose.yml
STOCK_ANALYST_ENV=dev

# ------------------------------------------------------------
# CACHE
# ------------------------------------------------------------

CACHE_DIR=data/cache
CACHE_TTL_HOURS=24

# ------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------

LOG_LEVEL=INFO
